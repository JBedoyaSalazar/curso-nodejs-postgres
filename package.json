    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "prettier": "^2.3.2",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5"
  },
  "dependencies": {
    "@faker-js/faker": "^7.6.0",
    "@hapi/boom": "^9.1.4",
    "cors": "^2.8.5",
